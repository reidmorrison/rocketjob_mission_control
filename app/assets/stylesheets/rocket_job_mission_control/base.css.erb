html, body, #wrapper, #wrapper > .container-fluid, #main {
  height: 100%;
}

/* Cosmic theme palette (ported from the semantic_logger v5 docs). */
:root {
  --cosmic-space:  #05060f;
  --cosmic-blue:   #1565d8;
  --cosmic-blue-dark: #0d47a1;
  --cosmic-flame:  #ff6a18;
  --cosmic-flame-border: #ff8a2a;
  /* Darker, muted flame for the selected/active state so it reads clearly
     without the bright orange glare. */
  --cosmic-flame-active: #a34a0c;
  --cosmic-code-bg: #0d1330;
  --cosmic-code-border: #232a4d;
  --cosmic-code-text: #e6e6f0;
}

/* Deep-space starfield header banner with a dark overlay, replacing the old
   red/black gradient. */
.navbar-default {
  background-color: var(--cosmic-space);
  background-image: linear-gradient(rgba(5, 8, 24, 0.78), rgba(5, 8, 24, 0.86)), url('<%= image_path("rocket_job_mission_control/header-banner.jpg") %>');
  background-size: cover;
  background-position: center;
}
.navbar-default .navbar-nav > li > a { color: rgba(255, 255, 255, 0.75); }
.navbar-default .navbar-nav > li > a:hover,
.navbar-default .navbar-nav > li > a:focus {
  color: #fff;
  background-color: rgba(255, 106, 24, 0.35);
}
.navbar-default .navbar-nav > .active > a,
.navbar-default .navbar-nav > .active > a:hover,
.navbar-default .navbar-nav > .active > a:focus {
  color: #fff;
  background-color: var(--cosmic-flame-active);
}
.navbar-default .navbar-collapse, .navbar-default .navbar-form {
  border: 0;
}

#wrapper { background-color: #f7f7f7; }

/* Cosmic-blue link accent. Deliberately a bare `a` selector (specificity 0,0,0,1)
   so it overrides Bootstrap's default link color but still loses to the more
   specific status-colored links (e.g. `.callout-running a`) and to nav/sidebar
   links, which keep their own colors. */
a { color: var(--cosmic-blue); }
a:hover, a:focus { color: var(--cosmic-blue-dark); }

.footer {
  position: relative;
  height: 100px;
  clear: both;
  padding-top: 20px;
}

/* Datatables */
table.datatable { border-collapse: collapse; }
.dt-container { margin-top: 0; }

/* The DataTables Bootstrap 5 integration tags every toolbar row with `mt-2`,
   which stacks extra whitespace above and below the length/search controls.
   Drop it so the toolbar sits tight against the table. */
.dt-container .dt-layout-row { margin-top: 0; }

table.dataTable thead .sorting:after, table.dataTable thead .sorting_asc:after, table.dataTable thead .sorting_desc:after {
  position: absolute;
  top: 8px;
  left: 8px;
  display: block;
  font-family: "Font Awesome 5 Free";
  font-size: inherit;
  text-rendering: auto;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

table.dataTable thead .sorting:after { content: "\f0c9"; }
table.dataTable thead .sorting_asc:after { content: "\f160"; }
table.dataTable thead .sorting_desc:after { content: "\f161"; }
table.dataTable thead > tr > th { padding-left: 30px; }

.dt-info, .dt-paging { margin-top: 20px !important; }

.datatable .rjmc-card td { vertical-align: middle; }

/* Row action buttons: compact, themed cosmic-blue to match the toolbar. The
   `a.btn` selector is needed to outrank the per-row `.callout-<state> a` link
   colors (rows get a `callout-<state>` class), which would otherwise tint the
   button text green/red/etc. */
.inline-job-actions > a.btn {
  display: inline-block;
  margin: 0 2px;
  padding: 2px 9px;
  font-size: 12px;
  line-height: 1.6;
  color: #fff;
  background-color: var(--cosmic-blue);
  background-image: none;
  border: 1px solid var(--cosmic-blue-dark);
  border-radius: 3px;
  box-shadow: 0 1px 2px rgba(13, 19, 48, 0.25);
}
.inline-job-actions > a.btn:hover,
.inline-job-actions > a.btn:focus {
  color: #fff;
  text-decoration: none;
  background-color: var(--cosmic-blue-dark);
  border-color: var(--cosmic-blue-dark);
}

/* Primary buttons (Save/Edit and form submits) themed to the cosmic-blue accent. */
.btn-primary {
  background-color: var(--cosmic-blue);
  border-color: var(--cosmic-blue-dark);
}
.btn-primary:hover,
.btn-primary:focus,
.btn-primary:active,
.btn-primary.active {
  color: #fff;
  background-color: var(--cosmic-blue-dark);
  border-color: var(--cosmic-blue-dark);
}

/* Secondary buttons (Cancel and other non-primary actions): a solid light-grey
   fill instead of Bootstrap's default white, so they read as buttons against
   the page background. */
.btn-default {
  color: #333;
  background-color: #e6e9f0;
  border-color: #c7cede;
}
.btn-default:hover,
.btn-default:focus,
.btn-default:active,
.btn-default.active {
  color: #333;
  background-color: #d4d9e6;
  border-color: #b3bbd0;
}

/* Center the show-page action toolbar and let its groups flow inline. */
.job-actions {
  margin-left: 0;
  text-align: center;
}
.job-actions .btn-group,
.job-actions .left-margin {
  float: none;
  display: inline-block;
  vertical-align: top;
  margin-left: 0;
}

/* Detail/show page action toolbar buttons -> cosmic-blue, spaced as
   individual buttons (they otherwise sit flush as a btn-group). */
.job-actions .btn {
  margin: 0 3px 4px 3px;
  color: #fff;
  background-color: var(--cosmic-blue);
  background-image: none;
  border: 1px solid var(--cosmic-blue-dark);
  border-radius: 4px;
}
.job-actions .btn:hover,
.job-actions .btn:focus,
.job-actions .btn:active {
  color: #fff;
  background-color: var(--cosmic-blue-dark);
  border-color: var(--cosmic-blue-dark);
}

/* Detail/show page label:value tables: full width with a clean, professional
   look - zebra striping, comfortable padding, and a muted bold label column
   shrunk to its content so the value column takes the rest. */
.col-md-12 > table {
  width: 100%;
  margin-bottom: 1.5em;
  border: 1px solid #e6e9f0;
  border-radius: 4px;
}
.col-md-12 > table td {
  padding: 7px 14px;
  vertical-align: top;
}
.col-md-12 > table tr:nth-child(even) {
  background-color: #f5f7fb;
}
.col-md-12 > table td:first-child {
  width: 1%;
  white-space: nowrap;
  color: #5a6572;
}
.col-md-12 > table td:first-child label {
  margin-bottom: 0;
  font-weight: 600;
  color: inherit;
}

/* Input/Output Categories sub-panels themed to the brand two-tone:
   Input (panel-primary) = cosmic blue, Output (panel-success) = flame orange. */
.panel-primary { border-color: var(--cosmic-blue); }
.panel-primary > .panel-heading {
  color: #fff;
  background-color: var(--cosmic-blue);
  border-color: var(--cosmic-blue);
}
.panel-primary > .panel-heading + .panel-collapse > .panel-body { border-top-color: var(--cosmic-blue); }

.panel-success { border-color: #e8760f; }
.panel-success > .panel-heading {
  color: #fff;
  background-color: #e8760f;
  border-color: #e8760f;
}
.panel-success > .panel-heading + .panel-collapse > .panel-body { border-top-color: #e8760f; }

.job-list {
  height: 100%;
  min-height: 768px;
}

/* Job Edit Page */
.edit_job textarea.description-block { height: 166px; }
.edit_job .buttons { margin-top: 1em; }

.job-status .lead {
  color: #50555b;
  float: left;
  margin-top: 1em;
  vertical-align: middle;
}

.job-status p {
  font-size: 14px;
  color: #666;
}

.job-status .welcome_screen {
  text-align: center;
  margin-top: 2%;
}

.job-status .welcome_screen h1 { margin-bottom: 10px; }
.job-status .welcome_screen p { font-size: 16px; }

.job-status .job-actions {
  float: left;
  margin-top: 23px;
  margin-left: 20px;
}

.job-status .job-actions .btn { padding: 2px 6px; }

.job-status .pagination-buttons {
  float: left;
  margin-top: 23px;
  margin-left: 20px;
}

.job-status .job-state {
  margin-left: 20px;
  padding: 0;
  font-size: 12px;
  margin-top: 0;
  vertical-align: middle;
  float: left;
}

h3 { margin-top: 0; }

.job-status .job-state .left {
  float: left;
  text-shadow: 0 2px 3px #000;
  font-weight: bold;
  background-color: #404650;
  color: #fff;
  padding: 6px 12px;
  border-top-left-radius: 3px;
  border-bottom-left-radius: 3px;
}

.job-status .job-state .right {
  float: left;
  font-weight: bold;
  color: #fff;
  padding: 6px 12px;
  border-top-right-radius: 3px;
  border-bottom-right-radius: 3px;
}

.job-status .job-state .queued, .job-status .job-state .pending { background-color: #a29f00; }
.job-status .job-state .scheduled { background-color: purple; }
.job-status .job-state .running { background-color: #337ab7; }
.job-status .job-state .sleeping { background-color: darkcyan; }
.job-status .job-state .completed, .job-status .job-state .enabled { background-color: green; }
.job-status .job-state .paused, .job-status .job-state .disabled { background-color: orange; }
.job-status .job-state .failed { background-color: red; }
.job-status .job-state .aborted { background-color: darkorange; }

/* Batch job slice progress bar: a single horizontal stacked bar whose
   segments reuse the state colors above (Queued, Active, Failed, Completed). */
.slice-bar {
  display: flex;
  width: 100%;
  max-width: 600px;
  height: 22px;
  border-radius: 3px;
  overflow: hidden;
  background-color: #eee;
}

.slice-bar-segment { height: 100%; }
.slice-bar-segment.queued    { background-color: #a29f00; }
.slice-bar-segment.running   { background-color: #337ab7; }
.slice-bar-segment.failed    { background-color: red; }
.slice-bar-segment.completed { background-color: green; }

.slice-bar-legend {
  margin-top: 6px;
  font-size: 12px;
}

.slice-bar-legend-item {
  display: inline-block;
  margin-right: 12px;
  white-space: nowrap;
}

.slice-bar-swatch {
  display: inline-block;
  width: 10px;
  height: 10px;
  margin-right: 4px;
  border-radius: 2px;
  vertical-align: middle;
}

.slice-bar-swatch.queued    { background-color: #a29f00; }
.slice-bar-swatch.running   { background-color: #337ab7; }
.slice-bar-swatch.failed    { background-color: red; }
.slice-bar-swatch.completed { background-color: green; }

.job-status .priority {
  display: inline-block;
  vertical-align: middle;
  float: right;
  margin-top: 20px;
}

.job-status .priority .form-control {
  width: 47px;
  height: 34px;
}

.job-status .priority-set {
  float: right;
  padding: 7px 14px;
  font-weight: bold;
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
}

#content {
  margin-top: 60px;
  padding: 15px;
}

#main { padding-left: 0; }

.white-background { background-color: #fff; }

/* Sidebar - cosmic deep-space rail matching the header. */
#sidebar {
  padding: 0px;
  /* Was margin-top:5em + padding-top:15px. Use padding instead so the dark rail
     runs up behind the fixed header rather than leaving a light gap, and stretch
     it to full viewport height. */
  margin-top: 0;
  padding-top: calc(5em + 15px);
  min-height: 100vh;
  /* Dark grey brushed-metal rail, sampled from the chrome rocket icon
     (#5B5D62 body metal -> #3E454F gunmetal shadow). Clearly distinct from the
     near-black header. */
  background-color: #494b50;
  background-image: linear-gradient(180deg, #494b50 0%, #2c313a 100%);
}

#sidebar, #sidebar a {
  color: rgba(255, 255, 255, 0.75);
  background-color: transparent;
  padding-left: 5px;
}

/* Bootstrap 5 has no `.nav > li > a { display:block }` rule, so bare sidebar
   links render inline. Make each its own full-width row -- otherwise the two
   links (Create + All) in the dirmon list item sit on one line. */
#sidebar .nav a {
  display: block;
  padding: 4px 5px;
}

#sidebar .nav > li > a:hover,
#sidebar .nav > li > a:focus {
  color: #fff;
  background-color: rgba(255, 106, 24, 0.35);
}

#sidebar .nav > .active > a,
#sidebar .nav > .active > a:hover,
#sidebar .nav > .active > a:focus {
  color: #fff;
  background-color: var(--cosmic-flame-active);
}

/* Fixed-width sidebar rail on wide screens. The sidebar is taken out of flow
   (position: fixed) so it no longer shares Bootstrap's float row with #main;
   #main simply reserves 180px on the left. This avoids the content dropping
   below the tall floated sidebar. Below 769px the layout falls back to
   Bootstrap's offcanvas grid, which shrinks the sidebar to icons. */
@media screen and (min-width: 769px) {
  #sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 180px;
    overflow-y: auto;
    z-index: 900; /* below the fixed header (z-index 1000) */
  }
  #main {
    float: none;
    width: auto;
    margin-left: 180px;
  }
}

@media screen and (max-width: 768px) {
  .row-offcanvas {
    position: relative;
    -webkit-transition: all 0.25s ease-out;
    -moz-transition: all 0.25s ease-out;
    transition: all 0.25s ease-out;
  }

  .row-offcanvas-left.active { left: 33%; }

  .row-offcanvas-left.active .sidebar-offcanvas {
    left: -33%;
    position: absolute;
    top: 0;
    width: 33%;
    margin-left: 5px;
  }

  #sidebar, #sidebar a, #sidebar-footer a { padding-left: 6px; }
}

/* Header Styles */
#header {
  padding: 5px;
  border-radius: 0;
  border: 0;
  position: fixed;
  z-index: 1000;
  top: 0;
  right: 0;
  left: 0;
}

#header .navbar { position: relative; }

#header .brand {
  position: absolute;
  left: 50%;
  margin-left: -96px !important;
  display: block;
}

#header .brand img {
  display: inline;
  height: 40px;
  position: relative;
  bottom: 3px;
  left: 8px;
}

#header .first { left: 15px; }
#header .last { right: 15px; }

#header a.navbar-brand.brand {
  font-size: 23px;
  color: white;
  font-weight: bold;
  top: -5px;
}

/* Two-tone glossy brand title echoing the key art: blue "Rocket", orange "Job".
   Falls back to solid colors where background-clip:text is unsupported. */
#header a.navbar-brand.brand span {
  display: inline-block;
  position: relative;
  font-weight: bold;
  filter: drop-shadow(0 2px 3px rgba(0, 0, 0, 0.6));
}
#header a.navbar-brand.brand span.brand-rocket { color: #3a9bff; }
#header a.navbar-brand.brand span.brand-job { color: #ff9e3d; margin-left: 0.25em; }

@supports ((-webkit-background-clip: text) or (background-clip: text)) {
  #header a.navbar-brand.brand span.brand-rocket,
  #header a.navbar-brand.brand span.brand-job {
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  #header a.navbar-brand.brand span.brand-rocket {
    background-image: linear-gradient(180deg, #9ad4ff 0%, #3a9bff 55%, #0d5ad6 100%);
  }
  #header a.navbar-brand.brand span.brand-job {
    background-image: linear-gradient(180deg, #ffd27a 0%, #ff9e3d 55%, #f3700f 100%);
  }
}

#jobs-menu {
  margin-top: 1.5em;
  background-color: #b3b3b3;
  border-color: white;
}

.job-search-box { padding: 20px 100px; }

.list .rjmc-card:nth-child(1) { border-top: 1px solid #ddd; }
.list .rjmc-card:nth-child(odd) { background-color: #fff; }

.list .rjmc-card {
  border-bottom: 1px solid #ddd;
  border-right: 1px solid #ddd;
  height: 100%;
  background-color: #f7f7f7;
}

.list .rjmc-card:hover {
  cursor: pointer;
  background-color: #dadada;
}

/* Bootstrap 5 paints every table cell with var(--bs-table-bg), which hides a
   background set on the <tr>. Re-apply the zebra striping and hover onto the
   cells so the alternating row colors show on the list tables. The hover rule
   is last so it wins over the odd-row rule at equal specificity. */
.list .rjmc-card td { background-color: #f7f7f7; }
.list .rjmc-card:nth-child(odd) td { background-color: #fff; }
.list .rjmc-card:hover td { background-color: #dadada; }

.list .rjmc-card .inner {
  padding: 0.5em;
  position: relative;
  margin: 0 0 0 10px;
}

.list .rjmc-card .inner .title {
  display: inline-block;
  vertical-align: middle;
}

.list .rjmc-card .inner .title i.queued,    .page-title i.queued    { color: #a29f00; }
.list .rjmc-card .inner .title i.scheduled, .page-title i.scheduled { color: purple; }
.list .rjmc-card .inner .title i.running,   .page-title i.running   { color: #337ab7; }
.list .rjmc-card .inner .title i.sleeping,  .page-title i.sleeping  { color: darkcyan; }
.list .rjmc-card .inner .title i.completed, .page-title i.completed { color: green; }
.list .rjmc-card .inner .title i.paused,    .page-title i.paused    { color: orange; }
.list .rjmc-card .inner .title i.failed,    .page-title i.failed    { color: red; }
.list .rjmc-card .inner .title i.aborted,   .page-title i.aborted   { color: darkorange; }
.list .rjmc-card .inner .title i.enabled,   .page-title i.enabled   { color: green; }
.list .rjmc-card .inner .title i.disabled,  .page-title i.disabled  { color: orange; }

/* Jobs/servers/dirmon list page title: cosmic-blue heading (theme accent) with
   a state-colored status icon. */
.page-title {
  color: var(--cosmic-blue);
  font-weight: normal;
  margin: 0;
  font-size: 22px;
  line-height: 1.2;
}
.page-title i {
  margin-right: 0.35em;
  font-size: 0.85em;
}
/* Server- and dirmon-specific states (not present in the card-list rules above). */
.page-title i.starting { color: #337ab7; }
.page-title i.stopping { color: darkorange; }
.page-title i.zombie   { color: darkred; }
.page-title i.pending  { color: orange; }

/* Title bar for the list panel heading: a lighter version of the gunmetal
   sidebar gradient. Title text goes light for contrast; the state-colored icon
   still pops. */
.page-title-bar {
  padding-top: 8px;
  padding-bottom: 8px;
  background-color: #5b5d62;
  background-image: linear-gradient(180deg, #5b5d62 0%, #494b50 100%);
  border-bottom-color: #3e454f;
}
.page-title-bar .page-title {
  color: #eef2fb;
}
/* Links in the title (e.g. the job-class link on the slice/exception pages)
   stay readable on the dark bar. */
.page-title-bar .page-title a {
  color: #fff;
  text-decoration: underline;
}
.page-title-bar .page-title a:hover,
.page-title-bar .page-title a:focus {
  color: #fff;
  text-decoration: none;
}
/* Keep pagination controls from inflating the title-bar height so it matches
   the other list titles. */
.page-title-bar .pagination-buttons,
.page-title-bar .pagination-buttons .pagination {
  margin: 0;
}

/* Consistent, themed section sub-headers on the detail/show pages
   (Details, Dates, Exceptions, Input Categories, ...). */
.section-header {
  margin: 1.5em 0 0.75em;
  padding-bottom: 6px;
  font-size: 18px;
  font-weight: bold;
  color: var(--cosmic-blue);
  border-bottom: 2px solid #dce3f0;
}
.section-header:first-child {
  margin-top: 0;
}
/* Nested sub-header (e.g. each category name under Input/Output Categories). */
.subsection-header {
  margin: 1em 0 0.5em;
  font-size: 15px;
  font-weight: bold;
  color: var(--cosmic-blue);
}

/* Job exception backtrace: one frame per row, with a right-aligned line number.
   Noise frames (gems / Ruby internals) are hidden until the "Full Backtrace"
   toggle adds `show-full` to the table (see backtrace.js). */
.section-header .backtrace-toggle {
  float: right;
  font-weight: normal;
}
.backtrace .backtrace-line-number {
  width: 1%;
  text-align: right;
  color: #999;
  white-space: nowrap;
  padding-right: 12px;
}
.backtrace .backtrace-noise {
  display: none;
}
.backtrace.show-full .backtrace-noise {
  display: table-row;
}

/* Job slice records: one record per row with a right-aligned line number and a
   per-row Edit action. The record that raised the exception is highlighted. */
.records .records-line-number {
  width: 1%;
  text-align: right;
  color: #999;
  white-space: nowrap;
  padding-right: 12px;
}
.records .records-action {
  width: 1%;
  white-space: nowrap;
  text-align: right;
}
.records code {
  white-space: pre-wrap;
  word-break: break-word;
}
/* Highlight the failed record row. Target the cells, not the <tr>: Bootstrap 5
   paints each cell with var(--bs-table-bg), which would cover a row-level
   background. */
.records .records-failed td {
  background-color: #fdecea;
}
.records .records-failed .records-line-number {
  color: var(--danger, #d9534f);
  font-weight: bold;
}

/* Slice record editor: full-width, monospace textarea sized for long records
   (up to a few KB), with spaced action buttons below it. */
textarea.input_slices {
  font-family: monospace;
  margin-bottom: 1em;
}

/* Highlight for an unprintable / invalid byte rendered as a \xHH escape in a
   read-only record, so the byte that broke the record stands out. */
.record-escape {
  padding: 0 3px;
  color: #a94442;
  background-color: #fdecea;
  border: 1px solid #f0c5c1;
  border-radius: 3px;
  font-weight: bold;
}
#submit .btn {
  margin-right: 6px;
}

/* Themed collection-action buttons in the DataTables toolbar: individual,
   spaced, cosmic-blue buttons with a darker-blue hover (matches links/nav). */
.dt-toolbar-actions .btn {
  margin: 0 3px;
  padding: 5px 12px;
  color: #fff;
  background-color: var(--cosmic-blue);
  background-image: none;
  border: 1px solid var(--cosmic-blue-dark);
  border-radius: 4px;
  box-shadow: 0 1px 2px rgba(13, 19, 48, 0.25);
}
.dt-toolbar-actions .btn:hover,
.dt-toolbar-actions .btn:focus,
.dt-toolbar-actions .btn:active {
  color: #fff;
  background-color: var(--cosmic-blue-dark);
  border-color: var(--cosmic-blue-dark);
}

.list .rjmc-card .inner .title h3 {
  font-weight: bold;
  margin: 0;
  font-size: 16px;
}

.list .rjmc-card .inner .lead {
  margin-bottom: 5px;
  font-size: 18px;
}

.list .rjmc-card .inner .duration, .list .rjmc-card .inner .description, .list .rjmc-card .inner .completion {
  color: #7c735c;
  font-size: 18px;
  font-weight: 200;
}

.list .rjmc-card .inner .batch {
  position: absolute;
  right: -10px;
  top: -10px;
  background-color: #444;
  border-radius: 30px;
  padding: 4px 10px;
  color: #fff;
  z-index: 2;
}

.list .selected {
  border-bottom: 1px solid blue;
  border-right: 1px solid blue;
  border-top: 1px solid blue;
  background-color: lightcyan;
}

.grid {
  padding: 1em;
  font-size: 0.85em;
}

.grid .rjmc-card { padding: 1em; }

.grid .rjmc-card .inner {
  padding: 1em;
  border-radius: 3px;
  display: inline-block;
  background: #fff;
  width: 100%;
  min-height: 250px;
  box-sizing: border-box;
  -moz-box-sizing: border-box;
  -webkit-box-sizing: border-box;
  box-shadow: 0px 1px 2px 0 #ccc;
  position: relative;
  text-align: center;
}

.grid .rjmc-card .inner .title,
.grid .rjmc-card .inner .state,
.grid .rjmc-card .inner .threads,
.grid .rjmc-card .inner .time {
  margin-bottom: 10px;
}

.grid .rjmc-card .inner .actions {
  padding: 10px 0;
  background: #f5f5f5;
  border: 1px solid #eee;
  border-radius: 2px;
}

.grid .rjmc-card .inner .title { text-align: center; }

.grid .rjmc-card .inner .title h3 {
  font-weight: bold;
  margin: 0;
  font-size: 16px;
}

.priority-group {
  width: 67px;
  margin: 0 auto;
}

.priority-group input { text-align: right; }

.priority-group .input-group-btn-vertical {
  position: relative;
  white-space: nowrap;
  width: 1%;
  vertical-align: middle;
  display: table-cell;
}

.priority-group .input-group-btn-vertical > .btn {
  display: block;
  float: none;
  width: 100%;
  max-width: 100%;
  padding: 8px;
  margin-left: -1px;
  position: relative;
  border-radius: 0;
}

.priority-group .input-group-btn-vertical > .btn:first-child { border-right: 0; }

.priority-group .input-group-btn-vertical > .btn:last-child {
  margin-top: -2px;
  border-right: 0;
}

.priority-group .input-group-btn-vertical i {
  position: absolute;
  top: 0;
  left: 4px;
}

.code-block { margin-top: 25px; }
.status { padding: 1em; }
