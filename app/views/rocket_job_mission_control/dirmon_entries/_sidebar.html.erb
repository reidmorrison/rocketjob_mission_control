<ul class='nav flex-column d-none d-sm-flex' id='lg-menu'>
  <li class="<%= 'active' if current_page?(dirmon_entries_path) || current_page?(new_dirmon_entry_path) %>">

    <% if can?(:create, RocketJob::DirmonEntry) %>
      <%= link_to(new_dirmon_entry_path) do %>
        <i class='fas fa-plus'></i> Create
      <% end %>
    <% end %>

    <%= link_to(dirmon_entries_path) do %>
      <i class='fas fa-list'></i> All
    <% end %>
  </li>

  <% RocketJob::DirmonEntry.aasm.states.map { |s| s.name.to_s }.each do |state| %>
    <li class="<%= state %><%= ' active' if current_page?(send("#{state}_dirmon_entries_path")) %>">
      <%= link_to("#{state}_dirmon_entries".to_sym) do %>
        <i class="fas <%= state_icon(state) %>"></i> <%= state.capitalize %> (<%= dirmon_counts_by_state(state) %>)
      <% end %>
    </li>
  <% end %>
</ul>

<!-- tiny only nav -->

<ul class='nav flex-column d-flex d-sm-none' id='xs-menu'>
  <li>
    <%= link_to(new_dirmon_entry_path) do %>
      <i class='fas fa-plus'></i>
    <% end %>

    <%= link_to(dirmon_entries_path) do %>
      <i class='fas fa-list'></i>
    <% end %>
  </li>

  <% RocketJob::DirmonEntry.aasm.states.map { |s| s.name.to_s }.each do |state| %>
    <li class="<%= state %>">
      <%= link_to("#{state}_dirmon_entries".to_sym) do %>
        <i class="<%= state_icon(state) %>"></i>
      <% end %>
    </li>
  <% end %>
</ul>
