<div class='dirmon-list'>
  <div class='list'>
    <div class="card">
      <div class="card-header page-title-bar">
        <div class='row'>
          <div class='col-sm-10'>
            <% state = @description.to_s.downcase %>
            <h2 class='page-title'>
              <% if state?(state) %><i class="<%= state_icon(state) %>"></i><% end %><%= @description %> Dirmon Entries
            </h2>
          </div>

          <div class='col-sm-2'>
            <div class='btn btn-default pull-right dt-reload' data-behavior='reload'>
              <i class='fas fa-sync'></i>
            </div>
          </div>
        </div>
      </div>

      <div class="card-body">
        <table class='table datatable dirmon-datatable' data-source='<%= @data_table_url %>' style='width: 100%'>
          <thead>
            <tr>
              <th>Name</th>
              <th>Job Class</th>
              <th>Pattern</th>
            </tr>
          </thead>

          <tbody></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  jQuery(function () {
    new RjmcDatatable(
      $(".dirmon-datatable"), [{data: '0'}, {data: '1'}, {data: '2'}]
    );
  });
</script>
