<div id='servers'>
  <div class='server-list'>
    <div class='list'>
      <div class="card">
        <div class="card-header page-title-bar">
          <div class='row'>
            <div class='col-sm-10'>
              <% state = @description.to_s.downcase %>
              <h2 class='page-title'>
                <% if state?(state) %><i class="<%= state_icon(state) %>"></i><% end %><%= @description %> Servers
              </h2>
            </div>

            <div class='col-sm-2'>
              <div class='btn btn-secondary float-end dt-reload' data-behavior='reload'>
                <i class='fas fa-sync'></i>
              </div>
            </div>
          </div>
        </div>

        <div class="card-body">
          <%# Hidden here on load, then placed by DataTables into the centered
              toolbar cell (see the `layout` option in the script below). %>
          <div id='server-collection-actions' class='dt-toolbar-actions text-center' style='display: none;'>
            <div class='action-buttons'>
              <% Array(@actions).each do |action| %>
                <% if can?(action, RocketJob::Server) %>
                  <%= link_to(
                          "#{action.to_s.humanize.capitalize}",
                          rocket_job_mission_control.update_all_servers_path(server_action: action),
                          method: :patch,
                          data:   {confirm: t(:confirm, scope: [:server, :update_all], action: action.to_s.singularize.humanize.downcase)},
                          class:  'btn btn-secondary'
                      ) %>
                <% end %>
              <% end %>
            </div>
          </div>

          <table class='table datatable servers-datatable' data-source='<%= @data_table_url %>' style='width: 100%'>
            <thead>
              <tr>
                <th>Hostname : PID</th>
                <th>Workers (Current/Max)</th>
                <th>Started</th>
                <th>Heartbeat</th>
                <th>Actions</th>
              </tr>
            </thead>

            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  jQuery(function () {
    // Reveal the server-side-rendered action buttons and hand the node to
    // DataTables, which places it in the centered (full-width) cell of the top
    // toolbar row: length (start) | actions (center) | search (end). This uses
    // the DataTables 2.x `layout` API, so no manual DOM move is needed.
    var actions = document.getElementById('server-collection-actions');
    actions.style.display = '';

    new RjmcDatatable(
      $('.servers-datatable'),
      [{data: '0'}, {data: '1'}, {data: '2'}, {data: '3'}, {data: '4', orderable: false}],
      {
        layout: {
          topStart: 'pageLength',
          top:      actions,
          topEnd:   'search'
        }
      }
    );
  });
</script>
