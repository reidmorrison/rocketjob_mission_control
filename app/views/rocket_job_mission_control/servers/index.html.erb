<div id='servers'>
  <div class='server-list'>
    <div class='list'>
      <div class="card">
        <div class="card-header page-title-bar">
          <div class='row'>
            <div class='col-sm-10'>
              <% state = @description.to_s.downcase %>
              <h2 class='page-title'>
                <% if state?(state) %><i class="<%= state_icon(state) %>"></i><% end %><%= @description %> Servers
              </h2>
            </div>

            <div class='col-sm-2'>
              <div class='btn btn-default pull-right dt-reload' data-behavior='reload'>
                <i class='fas fa-sync'></i>
              </div>
            </div>
          </div>
        </div>

        <div class="card-body">
          <%# Rendered here, then moved by the script into the DataTables toolbar,
              centered between "Show entries" and "Search". %>
          <div id='server-collection-actions' class='dt-toolbar-actions' style='display: none;'>
            <div class='action-buttons'>
              <% Array(@actions).each do |action| %>
                <% if can?(action, RocketJob::Server) %>
                  <%= link_to(
                          "#{action.to_s.humanize.capitalize}",
                          rocket_job_mission_control.update_all_servers_path(server_action: action),
                          method: :patch,
                          data:   {confirm: t(:confirm, scope: [:server, :update_all], action: action.to_s.singularize.humanize.downcase)},
                          class:  'btn btn-default'
                      ) %>
                <% end %>
              <% end %>
            </div>
          </div>

          <table class='table datatable servers-datatable' data-source='<%= @data_table_url %>' style='width: 100%'>
            <thead>
              <tr>
                <th>Hostname : PID</th>
                <th>Workers (Current/Max)</th>
                <th>Started</th>
                <th>Heartbeat</th>
                <th>Actions</th>
              </tr>
            </thead>

            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  jQuery(function () {
    new RjmcDatatable(
      $('.servers-datatable'),
      [{data: '0'}, {data: '1'}, {data: '2'}, {data: '3'}, {data: '4', orderable: false}],
      {
        // Three-column toolbar: length (left), actions (centered), search (right).
        dom: "<'row'<'col-sm-3'l><'col-sm-6 text-center dt-actions-slot'><'col-sm-3'f>>" +
             "<'row'<'col-sm-12'tr>>" +
             "<'row'<'col-sm-5'i><'col-sm-7'p>>"
      }
    );

    $('#server-collection-actions')
      .appendTo($('.servers-datatable').closest('.dataTables_wrapper').find('.dt-actions-slot'))
      .css('display', 'inline-block');
  });
</script>
